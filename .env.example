# =============================================================================
# Transpek Mail Automation — environment template
# =============================================================================
# Copy this file to `.env` and fill in real values:
#   copy .env.example .env
#
# For encrypted deployment (production):
#   1. Fill `.env`, then run: python encrypt_env.py  (requires ENV_KEY in shell)
#   2. Deploy `.env.enc` only; set ENV_KEY on the server (see init_app_command.txt)
#   3. App loads secrets via load_secrets() in app.py
#
# Never commit `.env` or `.env.enc` to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Email (SMTP) — used by all approval/response emails
# -----------------------------------------------------------------------------
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=workflowbot@yourcompany.com
SMTP_PASSWORD=your-smtp-password-or-app-password

# -----------------------------------------------------------------------------
# Flask application
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-string

FLASK_ENV=production

# Public URL of this app (approval links in emails)
BASE_URL=https://bot.yourcompany.com

# Password for /time-config admin page
TIME_CONFIG_PASSWORD=change-me-strong-password

# -----------------------------------------------------------------------------
# Approval link encryption (encrypt/decrypt request IDs in email URLs)
# -----------------------------------------------------------------------------
# Use a long random string; must match the key used when links were generated
ORDER_SECRET_HASHKEY=change-me-long-random-hash-key

# -----------------------------------------------------------------------------
# Email OTP (optional second factor on approve/reject pages)
# -----------------------------------------------------------------------------
REQUIRE_EMAIL_OTP=true
OTP_MAX_ATTEMPTS=3
OTP_TTL_IN_SECONDS=60

# -----------------------------------------------------------------------------
# Business Central — order release API (after PO/SO approval)
# -----------------------------------------------------------------------------
# Purchase order release endpoint (used as PURCHASE_ORDER_API_URL in app.py)
PO_API=http://your-bc-server:7148/YourBCInstance/ODataV4/PurchaseOrder_ReleasePurchaseOrder()?Company=Your%20Company%20Name

# Sales order release endpoint (used as SALES_ORDER_API_URL in app.py)
SO_API=http://your-bc-server:7148/YourBCInstance/ODataV4/Salesorder_ReleaseSalesOrder()?Company=Your%20Company%20Name

API_USERNAME=your-ntlm-username
API_PASSWORD=your-ntlm-password

# -----------------------------------------------------------------------------
# SQL Server / Business Central database
# -----------------------------------------------------------------------------
# SQLAlchemy URL wrapping an ODBC connection string.
# Example with SQL authentication:
DATABASE_URL=mssql+pyodbc:///?odbc_connect=DRIVER={ODBC Driver 18 for SQL Server};SERVER=your-server\instance;DATABASE=YourBCDatabase;UID=your-db-user;PWD=your-db-password;Encrypt=yes;TrustServerCertificate=yes;Connection Timeout=30;autocommit=True;

# Example with Windows authentication (uncomment and adjust):
# DATABASE_URL=mssql+pyodbc:///?odbc_connect=DRIVER={ODBC Driver 18 for SQL Server};SERVER=your-server;DATABASE=YourBCDatabase;Trusted_Connection=yes;Encrypt=yes;TrustServerCertificate=yes;Connection Timeout=30;autocommit=True;

# -----------------------------------------------------------------------------
# Encrypted .env (runtime only — do not put in .env file)
# -----------------------------------------------------------------------------
# Set in the shell before starting the app when using .env.enc:
#   set ENV_KEY=your-fernet-key-from-generate_key.py
# ENV_KEY is read by load_secrets.py, encrypt_env.py, and decrypt_env.py
